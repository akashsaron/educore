# EduCore Environment Variables
# Copy to .env — never commit the real .env

SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=your-app-name.onrender.com,localhost,127.0.0.1
DATABASE_URL=postgresql://user:password@host:5432/dbname
CORS_ALLOWED_ORIGINS=https://your-app-name.onrender.com,http://localhost:3000
REDIS_URL=redis://localhost:6379/0
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-school@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EduCore School <noreply@yourschool.in>

# Local dev defaults:
# DEBUG=True
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/educore_dev
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
